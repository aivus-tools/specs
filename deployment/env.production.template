# ============================================
# Aivus Production Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to git!
# Variable names mirror Specs/prod-docker-compose.yml.
# ============================================

# ===========================================
# DOMAINS & SSL
# ===========================================
# APP_DOMAIN serves the Next.js frontend (e.g. go.aivus.co).
# SERVICE_DOMAIN is the base for api/traefik/pgadmin/flower/databasus subdomains.
APP_DOMAIN=go.aivus.co
SERVICE_DOMAIN=aivus.co
ACME_EMAIL=admin@aivus.co

# ===========================================
# DOCKER IMAGES (GHCR)
# ===========================================
# Images are pulled from ghcr.io/aivus-tools/* by the compose file.
# Tags select which build to run (backend from main, frontend from master).
BACKEND_TAG=latest
FRONTEND_TAG=latest

# ===========================================
# DATABASE
# ===========================================
POSTGRES_DB=aivus
POSTGRES_USER=aivus
POSTGRES_PASSWORD=<CHANGE_ME>

# ===========================================
# PGADMIN
# ===========================================
PGADMIN_DEFAULT_EMAIL=admin@aivus.co
PGADMIN_DEFAULT_PASSWORD=<CHANGE_ME>

# ===========================================
# DJANGO SECRETS
# ===========================================
DJANGO_SECRET_KEY=<CHANGE_ME>
HMAC_SECRET=<CHANGE_ME>
API_KEY=<CHANGE_ME>
WIX_WEBHOOK_SECRET=<CHANGE_ME>

# ===========================================
# DJANGO CONFIGURATION
# ===========================================
DJANGO_ADMIN_URL=admin/
DJANGO_SECURE_SSL_REDIRECT=True

# ===========================================
# EMAIL (Resend via anymail)
# ===========================================
RESEND_API_KEY=<CHANGE_ME>
DJANGO_DEFAULT_FROM_EMAIL=noreply@aivus.co
DJANGO_SERVER_EMAIL=server@aivus.co

# ===========================================
# LLM (Vertex AI / Gemini)
# ===========================================
GOOGLE_CLOUD_PROJECT=<CHANGE_ME>
GOOGLE_CLOUD_LOCATION=us-central1
# Path on the host to the service account JSON with role "Vertex AI User".
# Mounted read-only into the containers as /app/vertex-credentials.json.
VERTEX_CREDENTIALS_PATH=/opt/aivus/secrets/vertex-credentials.json
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ===========================================
# SPEECH-TO-TEXT
# ===========================================
STT_MODEL=short
GOOGLE_CLOUD_SPEECH_LOCATION=global

# ===========================================
# GCP STORAGE
# ===========================================
DJANGO_GCP_STORAGE_BUCKET_NAME=aivus-production-media
# Path on the host to the GCS service account JSON.
# Mounted read-only into the containers as /app/gcp-credentials.json.
GCP_CREDENTIALS_PATH=/opt/aivus/secrets/gcp-credentials.json

# ===========================================
# SENTRY
# ===========================================
SENTRY_DSN=<CHANGE_ME>
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ===========================================
# NEXTAUTH
# ===========================================
NEXTAUTH_SECRET=<CHANGE_ME>
AUTH_GOOGLE_ID=<CHANGE_ME>
AUTH_GOOGLE_SECRET=<CHANGE_ME>

# ===========================================
# FRONTEND
# ===========================================
FRONTEND_DEBUG=false

# ===========================================
# BASIC AUTH (htpasswd format)
# Generate with: htpasswd -nb admin password
# ===========================================
TRAEFIK_BASIC_AUTH=admin:$apr1$...
FLOWER_BASIC_AUTH=admin:$apr1$...
